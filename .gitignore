# ---------------------- Python 项目核心忽略 ----------------------
# 字节码文件
__pycache__/
*.py[cod]
*$py.class

# 编译后的扩展
*.so

# 分发/打包
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# 虚拟环境（关键：避免提交本地虚拟环境）
venv/
env/
ENV/
ragvenv/  # 你的项目虚拟环境名称
*.env
.venv/

# ---------------------- 项目专属忽略项 ----------------------
# 数据文件（避免提交大文件/敏感数据）
data/  # 本地文档目录（如果需要提交空目录，可建 data/.gitkeep）
*.csv
*.xlsx
*.docx
*.pdf
*.md
*.txt

# 向量库文件（Chroma 存储目录，无需提交）
storage/
chroma/
.db
*.db

# 日志文件（避免提交运行日志）
*.log
embedding.log
agent.log
chroma_log.log

# Streamlit 相关（缓存/配置）
.streamlit/
*.streamlit
st_*

# 环境变量文件（含 API Key 等敏感信息）
.env
.env.local
.env.*
!.env.example  # 保留示例文件（如果有）

# ---------------------- 系统/编辑器忽略 ----------------------
# Windows 系统
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# macOS 系统
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Linux 系统
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# IDE/编辑器配置
.idea/  # PyCharm
.vscode/  # VS Code
*.swp
*.swo
*.vim
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
*.sublime-project

# ---------------------- 其他忽略项 ----------------------
# 缓存文件
*.cache
*.pid
*.seed
*.pid.lock

# 测试/覆盖率报告
htmlcov/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb